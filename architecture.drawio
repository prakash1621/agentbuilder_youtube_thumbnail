<?xml version="1.0" encoding="UTF-8"?>
<mxfile host="app.diagrams.net" type="device">
  <diagram name="YouTube Thumbnail Designer Architecture" id="thumbnail-designer">
    <mxGraphModel dx="1400" dy="1000" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="1700" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- TITLE -->
        <mxCell id="title" value="YouTube Thumbnail Designer  •  Reflexion Agent  •  Assignment 1" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=28;fontStyle=1;fontColor=#FFFFFF;fillColor=#B71C1C;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="50" y="30" width="1300" height="70" as="geometry" />
        </mxCell>

        <!-- LEFT PANEL: State schema -->
        <mxCell id="schema-bg" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E3F2FD;strokeColor=#1565C0;strokeWidth=3;" vertex="1" parent="1">
          <mxGeometry x="50" y="130" width="640" height="280" as="geometry" />
        </mxCell>
        <mxCell id="schema-title" value="ThumbnailState  (TypedDict or Pydantic)" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=20;fontStyle=1;fontColor=#0D47A1;" vertex="1" parent="1">
          <mxGeometry x="70" y="148" width="600" height="28" as="geometry" />
        </mxCell>
        <mxCell id="schema-fields" value="topic            : str&#10;search_summary   : str&#10;current_prompt   : str&#10;image_path       : str&#10;rating           : int&#10;critique         : str&#10;iteration        : int&#10;target_rating    : int    (default 8)&#10;max_iterations   : int    (default 3)&#10;history          : Annotated[list, add]" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontFamily=Courier New;fontSize=17;fontColor=#212121;spacing=6;" vertex="1" parent="1">
          <mxGeometry x="75" y="182" width="600" height="220" as="geometry" />
        </mxCell>

        <!-- RIGHT PANEL: Loop rules -->
        <mxCell id="legend-bg" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF8E1;strokeColor=#F57F17;strokeWidth=3;" vertex="1" parent="1">
          <mxGeometry x="740" y="130" width="610" height="280" as="geometry" />
        </mxCell>
        <mxCell id="legend-title" value="Loop rules  (what you must implement)" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=20;fontStyle=1;fontColor=#E65100;" vertex="1" parent="1">
          <mxGeometry x="760" y="148" width="580" height="28" as="geometry" />
        </mxCell>
        <mxCell id="legend-body" value="• Build the graph with LangGraph.&#10;• 5 nodes + 1 conditional edge (the loop).&#10;• Critic returns a structured rating (1–10) + critique.&#10;• If rating &lt; target  →  loop back to prompt_writer&#10;&#xa0;&#xa0;&#xa0;with the critique attached as feedback.&#10;• If rating ≥ target  OR  iteration ≥ max&#10;&#xa0;&#xa0;&#xa0;→  go to saver and finish.&#10;• `history` uses Annotated[list, add]  (appends).&#10;• Every other field overwrites by default." style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=17;fontColor=#212121;spacing=8;" vertex="1" parent="1">
          <mxGeometry x="760" y="182" width="580" height="220" as="geometry" />
        </mxCell>

        <!-- START -->
        <mxCell id="start" value="START" style="ellipse;whiteSpace=wrap;html=1;fillColor=#E0E0E0;strokeColor=#424242;strokeWidth=3;fontSize=20;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="180" y="450" width="180" height="60" as="geometry" />
        </mxCell>

        <!-- NODE 1: web_search -->
        <mxCell id="web_search" value="🔎    web_search&#10;&#10;Tavily search on the topic" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#B3E5FC;strokeColor=#0277BD;strokeWidth=3;fontSize=20;fontStyle=1;align=center;verticalAlign=middle;spacing=10;" vertex="1" parent="1">
          <mxGeometry x="100" y="550" width="340" height="100" as="geometry" />
        </mxCell>

        <mxCell id="state-search" value="State after  web_search" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FAFAFA;strokeColor=#0277BD;strokeWidth=2;fontSize=18;fontStyle=1;align=center;verticalAlign=top;spacingTop=10;" vertex="1" parent="1">
          <mxGeometry x="540" y="550" width="800" height="100" as="geometry" />
        </mxCell>
        <mxCell id="state-search-body" value="✚  search_summary  +bullet list" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontFamily=Courier New;fontSize=18;fontColor=#212121;spacingLeft=20;" vertex="1" parent="1">
          <mxGeometry x="560" y="590" width="760" height="50" as="geometry" />
        </mxCell>

        <!-- NODE 2: prompt_writer -->
        <mxCell id="prompt_writer" value="✍️    prompt_writer&#10;&#10;Write a DALL-E prompt&#10;(use critique on loops)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF59D;strokeColor=#F9A825;strokeWidth=3;fontSize=20;fontStyle=1;align=center;verticalAlign=middle;spacing=10;" vertex="1" parent="1">
          <mxGeometry x="100" y="700" width="340" height="120" as="geometry" />
        </mxCell>

        <mxCell id="state-prompt" value="State after  prompt_writer" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FAFAFA;strokeColor=#F9A825;strokeWidth=2;fontSize=18;fontStyle=1;align=center;verticalAlign=top;spacingTop=10;" vertex="1" parent="1">
          <mxGeometry x="540" y="700" width="800" height="120" as="geometry" />
        </mxCell>
        <mxCell id="state-prompt-body" value="►  current_prompt  = new DALL-E prompt" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontFamily=Courier New;fontSize=18;fontColor=#212121;spacingLeft=20;" vertex="1" parent="1">
          <mxGeometry x="560" y="750" width="760" height="50" as="geometry" />
        </mxCell>

        <!-- NODE 3: generator -->
        <mxCell id="generator" value="🎨    generator&#10;&#10;Call DALL-E 3&#10;Save the PNG to outputs/" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F8BBD0;strokeColor=#C2185B;strokeWidth=3;fontSize=20;fontStyle=1;align=center;verticalAlign=middle;spacing=10;" vertex="1" parent="1">
          <mxGeometry x="100" y="870" width="340" height="120" as="geometry" />
        </mxCell>

        <mxCell id="state-gen" value="State after  generator" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FAFAFA;strokeColor=#C2185B;strokeWidth=2;fontSize=18;fontStyle=1;align=center;verticalAlign=top;spacingTop=10;" vertex="1" parent="1">
          <mxGeometry x="540" y="870" width="800" height="120" as="geometry" />
        </mxCell>
        <mxCell id="state-gen-body" value="►  image_path  = outputs/iter_N.png&#10;►  iteration   = iteration + 1" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontFamily=Courier New;fontSize=18;fontColor=#212121;spacingLeft=20;spacingTop=10;" vertex="1" parent="1">
          <mxGeometry x="560" y="910" width="760" height="70" as="geometry" />
        </mxCell>

        <!-- NODE 4: critic -->
        <mxCell id="critic" value="🧐    critic&#10;&#10;Vision LLM rates the image&#10;Returns rating + critique" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#C8E6C9;strokeColor=#2E7D32;strokeWidth=3;fontSize=20;fontStyle=1;align=center;verticalAlign=middle;spacing=10;" vertex="1" parent="1">
          <mxGeometry x="100" y="1040" width="340" height="120" as="geometry" />
        </mxCell>

        <mxCell id="state-critic" value="State after  critic" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FAFAFA;strokeColor=#2E7D32;strokeWidth=2;fontSize=18;fontStyle=1;align=center;verticalAlign=top;spacingTop=10;" vertex="1" parent="1">
          <mxGeometry x="540" y="1040" width="800" height="120" as="geometry" />
        </mxCell>
        <mxCell id="state-critic-body" value="►  rating    = 1–10  (Pydantic)&#10;►  critique  = actionable feedback&#10;✚  history  += this iteration" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontFamily=Courier New;fontSize=18;fontColor=#212121;spacingLeft=20;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="560" y="1080" width="760" height="80" as="geometry" />
        </mxCell>

        <!-- CONDITIONAL EDGE: should_continue -->
        <mxCell id="decision" value="rating ≥ target ?&#10;OR&#10;iteration ≥ max ?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#FFCDD2;strokeColor=#B71C1C;strokeWidth=3;fontSize=18;fontStyle=1;fontColor=#880E4F;" vertex="1" parent="1">
          <mxGeometry x="140" y="1200" width="260" height="130" as="geometry" />
        </mxCell>

        <mxCell id="decision-note" value="should_continue  (conditional edge)&#10;&#10;Reads rating + iteration from state.&#10;Returns the next node name:&#10;&#10;&#xa0;&#xa0;&quot;saver&quot;          →  done&#10;&#xa0;&#xa0;&quot;prompt_writer&quot;  →  loop with critique" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#B71C1C;strokeWidth=2;dashed=1;fontSize=18;align=left;verticalAlign=middle;spacing=14;" vertex="1" parent="1">
          <mxGeometry x="540" y="1200" width="800" height="130" as="geometry" />
        </mxCell>

        <!-- NODE 5: saver -->
        <mxCell id="saver" value="💾    saver&#10;&#10;Pick highest-rated image&#10;Write final.png + report.md" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E1BEE7;strokeColor=#6A1B9A;strokeWidth=3;fontSize=20;fontStyle=1;align=center;verticalAlign=middle;spacing=10;" vertex="1" parent="1">
          <mxGeometry x="100" y="1370" width="340" height="120" as="geometry" />
        </mxCell>

        <mxCell id="state-saver" value="State after  saver" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FAFAFA;strokeColor=#6A1B9A;strokeWidth=2;fontSize=18;fontStyle=1;align=center;verticalAlign=top;spacingTop=10;" vertex="1" parent="1">
          <mxGeometry x="540" y="1370" width="800" height="120" as="geometry" />
        </mxCell>
        <mxCell id="state-saver-body" value="Side-effect:  writes final.png and report.md&#10;to outputs/&lt;timestamp&gt;_&lt;topic&gt;/" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=18;fontColor=#212121;spacingLeft=20;spacingTop=10;" vertex="1" parent="1">
          <mxGeometry x="560" y="1410" width="760" height="70" as="geometry" />
        </mxCell>

        <!-- END -->
        <mxCell id="end" value="END" style="ellipse;whiteSpace=wrap;html=1;fillColor=#E0E0E0;strokeColor=#424242;strokeWidth=3;fontSize=20;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="180" y="1520" width="180" height="60" as="geometry" />
        </mxCell>

        <!-- EDGES -->
        <mxCell id="e1" style="endArrow=classic;html=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0;strokeWidth=3;" edge="1" parent="1" source="start" target="web_search">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e2" style="endArrow=classic;html=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0;strokeWidth=3;" edge="1" parent="1" source="web_search" target="prompt_writer">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e3" style="endArrow=classic;html=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0;strokeWidth=3;" edge="1" parent="1" source="prompt_writer" target="generator">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e4" style="endArrow=classic;html=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0;strokeWidth=3;" edge="1" parent="1" source="generator" target="critic">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e5" style="endArrow=classic;html=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0;strokeWidth=3;" edge="1" parent="1" source="critic" target="decision">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e6" value="YES" style="endArrow=classic;html=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0;strokeWidth=4;strokeColor=#2E7D32;fontStyle=1;fontColor=#2E7D32;fontSize=18;labelBackgroundColor=#FFFFFF;" edge="1" parent="1" source="decision" target="saver">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e7" style="endArrow=classic;html=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0;strokeWidth=3;" edge="1" parent="1" source="saver" target="end">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- LOOP arrow back to prompt_writer -->
        <mxCell id="loop" value="NO   rating &lt; target&#10;(loop with critique)" style="endArrow=classic;html=1;exitX=0;exitY=0.5;entryX=0;entryY=0.5;strokeWidth=4;strokeColor=#C62828;fontStyle=1;fontColor=#C62828;fontSize=18;edgeStyle=orthogonalEdgeStyle;rounded=1;labelBackgroundColor=#FFFFFF;" edge="1" parent="1" source="decision" target="prompt_writer">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="40" y="1265" />
              <mxPoint x="40" y="760" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- dotted connectors node → state-after -->
        <mxCell id="d1" style="endArrow=open;endFill=0;html=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5;strokeWidth=2;strokeColor=#0277BD;dashed=1;" edge="1" parent="1" source="web_search" target="state-search">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="d2" style="endArrow=open;endFill=0;html=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5;strokeWidth=2;strokeColor=#F9A825;dashed=1;" edge="1" parent="1" source="prompt_writer" target="state-prompt">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="d3" style="endArrow=open;endFill=0;html=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5;strokeWidth=2;strokeColor=#C2185B;dashed=1;" edge="1" parent="1" source="generator" target="state-gen">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="d4" style="endArrow=open;endFill=0;html=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5;strokeWidth=2;strokeColor=#2E7D32;dashed=1;" edge="1" parent="1" source="critic" target="state-critic">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="d5" style="endArrow=open;endFill=0;html=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5;strokeWidth=2;strokeColor=#B71C1C;dashed=1;" edge="1" parent="1" source="decision" target="decision-note">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="d6" style="endArrow=open;endFill=0;html=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5;strokeWidth=2;strokeColor=#6A1B9A;dashed=1;" edge="1" parent="1" source="saver" target="state-saver">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- legend at the bottom -->
        <mxCell id="legend-symbols" value="✚  appended  (add reducer)        ►  overwritten  (default reducer)" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=16;fontStyle=2;fontColor=#555555;" vertex="1" parent="1">
          <mxGeometry x="50" y="1610" width="1300" height="34" as="geometry" />
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
